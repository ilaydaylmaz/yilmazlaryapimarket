{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firestore-debug.log",
        "ui-debug.log",
        "public",
        "data",
        "scripts",
        "admin",
        "*.md",
        "Dockerfile",
        ".dockerignore",
        "render.yaml",
        "ecosystem.config.cjs",
        ".env",
        ".env.*"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api",
        "region": "europe-west1"
      },
      {
        "source": "/admin/**",
        "function": "api",
        "region": "europe-west1"
      }
    ]
  }
}
